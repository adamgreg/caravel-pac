/* Use DefaultHandler for external interrupts without a user-defined handler */
PROVIDE(Timer0 = DefaultHandler);
PROVIDE(Uart = DefaultHandler);
PROVIDE(User0 = DefaultHandler);
PROVIDE(User1 = DefaultHandler);
PROVIDE(User2 = DefaultHandler);
PROVIDE(User3 = DefaultHandler);
PROVIDE(User4 = DefaultHandler);
PROVIDE(User5 = DefaultHandler);
